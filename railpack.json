{
  "build": {
    "builder": "nixpacks"
  },
  "nixpacks": {
    "providers": ["python", "nodejs"],
    "buildCommands": [
      "pip install -r backend/requirements.txt",
      "cd frontend/web && npm ci && npm run build && cd ../.."
    ],
    "startCommand": "uvicorn backend.api.main:app --host 0.0.0.0 --port $PORT"
  }
}
